# Copy to .env and fill in. .env is gitignored.
#
# Most defaults in docker-compose.yaml are fine for a single-host local
# deployment. Override only what differs for your environment.

# --- Deployment mode ---
# local: dev on this machine. remote: production behind nginx + TLS.
ENVIRONMENT=local

# --- Public-facing URLs (only needed if ENVIRONMENT=remote) ---
# PUBLIC_HOST=voice.example.com
# PUBLIC_BASE_URL=https://voice.example.com
# BACKEND_API_ENDPOINT=https://voice.example.com
# MINIO_PUBLIC_ENDPOINT=https://voice.example.com
# SERVER_IP=1.2.3.4

# --- TURN server (WebRTC NAT traversal, only for remote) ---
# TURN_HOST=turn.example.com
# TURN_SECRET=change-me
# FORCE_TURN_RELAY=false

# --- Auth ---
# CHANGE THIS in any non-local deployment.
OSS_JWT_SECRET=ChangeMeInProduction

# --- Workers ---
FASTAPI_WORKERS=1

# --- Telemetry (opt out by setting to false) ---
ENABLE_TELEMETRY=true

# --- Optional: Langfuse tracing ---
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=

# --- SaaS Gateway ---
# Fernet key for encrypting secrets stored in the Control DB (email provider
# keys, plugin secrets, etc). Generate with:
#   docker run --rm python:3.12-slim sh -c "pip install -q cryptography \
#     && python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"
# REQUIRED for any email-provider config or plugin secret to work.
GATEWAY_SECRETS_KEY=

# First-boot super-admin bootstrap. If both are set AND no platform users
# exist yet, the gateway creates a super-admin with these credentials on
# startup. Leave blank after the first boot and rotate via the admin UI.
GATEWAY_BOOTSTRAP_SUPER_ADMIN_EMAIL=
GATEWAY_BOOTSTRAP_SUPER_ADMIN_PASSWORD=

# Optional demo customer tenant — handy for local dev so the customer app
# at :3030 has a working login out of the box. Creates a Dograh user, links
# a tenant + tenant_members row. All four must be set; skipped if a tenant
# with that owner_email already exists. Intended for non-prod only.
GATEWAY_BOOTSTRAP_DEMO_TENANT_EMAIL=
GATEWAY_BOOTSTRAP_DEMO_TENANT_PASSWORD=
GATEWAY_BOOTSTRAP_DEMO_TENANT_FULL_NAME=
GATEWAY_BOOTSTRAP_DEMO_TENANT_COMPANY_NAME=
